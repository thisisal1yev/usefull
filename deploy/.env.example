# Domain for the API (A-record must point to this VPS)
API_DOMAIN=api.example.uz

# --- server ---
BOT_TOKEN=123456:ABC-your-botfather-token
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service-role-key
BOT_MODE=webhook
PORT=3000
# random long string, e.g. `openssl rand -hex 32`
WEBHOOK_SECRET=
# Vercel URL of the Mini App (enables the bot's menu button)
WEBAPP_URL=
# Bot username (without @) — used to build referral invite links
BOT_USERNAME=usefull_bot

# Subscription prices in Telegram Stars
PREMIUM_STARS=350
GOLD_STARS=1000

# Only for docker-compose.behind-proxy.yml: host loopback port the existing
# reverse proxy forwards to (default 3001). Ignored by the default compose.
SERVER_PORT=3001
